# Copy to .env and adjust as needed. All vars are prefixed LANGUAGEAI_.
LANGUAGEAI_DEBUG=false
LANGUAGEAI_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Set to enable real Claude replies. If unset, the dummy generator is used and
# the standard ANTHROPIC_API_KEY env var (if present) is honored as a fallback.
# LANGUAGEAI_ANTHROPIC_API_KEY=sk-ant-...
LANGUAGEAI_ANTHROPIC_MODEL=claude-opus-4-8
