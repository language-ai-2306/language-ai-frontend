# Copy to .env.local to override. Leave empty to use the Vite dev proxy (/api).
VITE_API_BASE_URL=

# --- 3D avatar -------------------------------------------------------------
# Which avatar to render: "mascot" (Ollie the otter, default), "fox" (bundled),
# or "rpm" (Ready Player Me). Leave unset to get the mascot on local AND remote.
# VITE_AVATAR_KIND=mascot
# RPM avatar GLB URL. Create one in ~30s at https://readyplayer.me/avatar and
# paste its .glb link here. Morph-target params are appended automatically.
# VITE_RPM_AVATAR_URL=https://models.readyplayer.me/<your-id>.glb
